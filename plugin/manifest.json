{
  "manifest_version": 3,
  "name": "Consent OS — Privacy Monitor",
  "version": "1.0",
  "description": "Автоматически обнаруживает трекеры и сторонние сервисы на всех сайтах",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Consent OS",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
